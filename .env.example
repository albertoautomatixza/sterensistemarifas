NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for the production admin dashboard.
ADMIN_TOKEN=

# Comma-separated list for extra trusted origins, if the app is embedded behind
# a proxy or preview URL that does not match the request host.
ALLOWED_ORIGINS=

# Steren purchase validation API. Keep the key server-side only.
STEREN_API_URL=
STEREN_API_KEY=
STEREN_TIMEOUT_MS=5000

# Preview/demo mode. Leave empty in production unless you intentionally want
# server-local JSON storage for a non-production demo.
LOCAL_REGISTRATION_STORE=
LOCAL_REGISTRATION_DB_PATH=
