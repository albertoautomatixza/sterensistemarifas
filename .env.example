NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for the production admin dashboard.
# ADMIN_TOKEN is kept as a technical fallback for API access.
ADMIN_TOKEN=
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Optional transactional email provider for raffle confirmation tickets.
# Keep the API key server-side only.
RESEND_API_KEY=
MAIL_PROVIDER=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_TIMEOUT_MS=10000

# Comma-separated list for extra trusted origins, if the app is embedded behind
# a proxy or preview URL that does not match the request host.
ALLOWED_ORIGINS=

# Steren purchase validation API. Keep the key server-side only.
STEREN_API_URL=
STEREN_API_USERNAME=
STEREN_API_PASSWORD=
STEREN_API_KEY=
STEREN_TIMEOUT_MS=30000
STEREN_SALES_LOOKBACK_DAYS=31
STEREN_SALES_PAGE_SIZE=500
STEREN_SALES_MAX_PAGES=20

# Optional QA/debug window. Steren StoreGroups only allows yyyyMMdd ranges up to 31 days,
# and the current/future date is not accepted by the API.
STEREN_SALES_START_DATE=
STEREN_SALES_END_DATE=

# Preview/demo mode. Leave empty in production unless you intentionally want
# server-local JSON storage for a non-production demo.
LOCAL_REGISTRATION_STORE=
LOCAL_REGISTRATION_DB_PATH=
